Program Hello {
    var a = 42;
    var b = 7;
    var sum = a + b;
    var product = a * b;

    PrintLine("=== Y# Hello World ===");
    Print("42 + 7 = ");
    PrintLine(sum);
    Print("42 * 7 = ");
    PrintLine(product);

    var x = 100;
    var y = x - 58;
    Print("100 - 58 = ");
    PrintLine(y);

    PrintLine("Goodbye!")
}
