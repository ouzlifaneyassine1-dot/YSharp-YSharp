<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Y# (YSharp) v8.0.1" Language="1033" Version="8.0.1" Manufacturer="Y# Language Team" UpgradeCode="B5A1C3D2-E4F5-6789-ABCD-EF0123456789">
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Y# is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Directory structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="YSharp">
          <Directory Id="BINDIR" Name="bin" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="YSharpProgramMenu" Name="Y# (YSharp)" />
      </Directory>
    </Directory>

    <!-- Components -->
    <DirectoryRef Id="BINDIR">
      <Component Id="oys.exe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="oys.exe" Name="oys.exe" Source="..\dist\oys.exe" KeyPath="yes" />
      </Component>
      <Component Id="yo.exe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="yo.exe" Name="yo.exe" Source="..\dist\yo.exe" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Add to PATH -->
    <DirectoryRef Id="BINDIR">
      <Component Id="AddToPath" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Environment Id="PATH" Name="PATH" Value="[BINDIR]" Permanent="no" Part="last" Action="set" System="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="YSharpProgramMenu">
      <Component Id="Shortcuts" Guid="D4E5F6A7-B8C9-0123-DEF1-234567890123">
        <Shortcut Id="YSharpCMD" Name="Y# Command Prompt" Target="[SystemFolder]cmd.exe" Arguments="/K oys" Description="Open Y# command prompt" />
        <RemoveFolder Id="YSharpProgramMenu" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\YSharp" Name="installed" Type="integer" Value="1" />
      </Component>
    </DirectoryRef>

    <!-- Features -->
    <Feature Id="Complete" Title="Y# v8.0.1" Level="1">
      <ComponentRef Id="oys.exe" />
      <ComponentRef Id="yo.exe" />
      <ComponentRef Id="AddToPath" />
      <ComponentRef Id="Shortcuts" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

    <CustomAction Id="SetPath" Property="PATH" Value="[BINDIR];[PATH]" />
  </Product>
</Wix>
