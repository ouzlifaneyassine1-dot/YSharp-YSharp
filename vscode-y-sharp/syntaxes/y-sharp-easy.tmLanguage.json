{
  "name": "Y# Easy",
  "scopeName": "source.yse",
  "fileTypes": ["yse"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "//.*", "name": "comment.line.double-slash.yse" }
      ]
    },
    "strings": {
      "patterns": [
        { "begin": "'", "end": "'", "name": "string.quoted.single.yse" }
      ]
    },
    "numbers": {
      "patterns": [
        { "match": "\\b[0-9]+(\\.[0-9]+)?\\b", "name": "constant.numeric.yse" }
      ]
    },
    "keywords": {
      "patterns": [
        { "match": "\\b(fn|if|else|loop|while|for|return|var|let|const|print|println|null|true|false|entity|system|actor|view|state|on)\\b", "name": "keyword.control.yse" }
      ]
    },
    "builtins": {
      "patterns": [
        { "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*", "name": "variable.other.yse" }
      ]
    }
  }
}
