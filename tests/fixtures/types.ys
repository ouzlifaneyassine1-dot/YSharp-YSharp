Program TypeDemo {
    var x: Int = 42     // explicit type (optimized, unboxed)
    var y = 3.14        // inferred Float
    var name = "Y#"     // inferred String
    var flag = true     // inferred Bool
    
    PrintLine(x)
    PrintLine(y)
    PrintLine(name)
    
    var x: Int = 100        // explicit type (optimized, unboxed)
    PrintLine(x)
}
