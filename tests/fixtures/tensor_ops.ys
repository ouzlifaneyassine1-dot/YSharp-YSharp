Program TensorDemo {
    Tensor<f32, 2>[3, 3] a = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
    Tensor<f32, 2>[3, 3] b = [[9, 8, 7], [6, 5, 4], [3, 2, 1]]
    
    Tensor<f32, 2>[3, 3] c = MatMul(a, b)
    
    PrintLine("Matrix product:")
    ForEach(c) { row =>
        ForEach(row) { val =>
            Print(val)
            Print(" ")
        }
        PrintLine("")
    }
}
