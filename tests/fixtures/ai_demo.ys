Program AiDemo {
    Model model = LoadModel("yolo.onnx")
    Tensor<f32, 4>[1, 3, 224, 224] image = LoadImage("input.jpg")
    
    differentiable Inference() {
        Tensor<f32, 2>[1, 80] result = model.Forward(image)
        result = Softmax(result)
        Return result
    }
    
    var output = Inference()
    PrintLine("Detected objects:")
    ForEach(output) { obj =>
        PrintLine(obj.label + ": " + obj.confidence)
    }
}
